# 이 파일은 커밋됩니다. 실제 키를 절대 넣지 마세요.
# 로컬 개발: 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 .gitignore 로 막혀 있습니다)
#
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ 접두사를 붙이면 브라우저 번들에 그대로 노출됩니다.
# 아래 키들은 전부 서버 전용이므로 접두사를 붙이지 마세요.

# --- 현재 사용 중 (둘 다 무료, 가입 즉시 발급) ---

# https://fred.stlouisfed.org/docs/api/api_key.html
# 미 국채금리 · 연방기금금리 · 나스닥 · WTI · 브렌트
FRED_KEY=

# https://ecos.bok.or.kr/api/#/AuthKeyApply
# 국고채 3년 · 기준금리 · 원달러 · 달러엔 · 코스피 · 코스닥
ECOS_KEY=

# https://twelvedata.com — 무료(basic) 티어: 분당 8콜 · 일 800콜.
# 환율(USD/KRW·USD/JPY) 당일 장중 값. 없으면 ECOS 전일 종가로 자동 폴백.
# 주의: WTI/브렌트/ICE DXY 는 무료 티어에서 제공되지 않음 (실측 확인, 2026-07).
TWELVEDATA_KEY=

# 신호 등급 임계값 T (선택). 기본 1.5 — scripts/calibrate-threshold.ts 백테스트로 산출.
# SIGNAL_THRESHOLD=1.5

# --- 아직 미사용 ---

# https://apiportal.koreainvestment.com — 한국투자증권 실계좌 필요.
# 국내 지수는 ECOS 로 대체했으므로, 장중 실시간 수급이 필요할 때만 발급하세요.
KIS_APP_KEY=
KIS_APP_SECRET=
